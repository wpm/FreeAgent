{
  "additionalProperties": false,
  "description": "A serializable, versioned unit of work: one launchable role of one episode.\n\nWire-safe (round-trips JSON) and self-contained: a child is launchable purely\nfrom a manifest via :meth:`to_child_spec`. References code by\n:attr:`cls` import path; never carries code.\n\nRole-specific fields are validated by :meth:`_check_role_fields`: an\n``agent`` requires :attr:`subject_root` and :attr:`agent_id`; an\n``environment`` requires :attr:`app`, :attr:`roster`, and :attr:`episode_id`.",
  "properties": {
    "role": {
      "enum": [
        "agent",
        "environment"
      ],
      "type": "string"
    },
    "class": {
      "type": "string"
    },
    "config": {
      "additionalProperties": true,
      "type": "object"
    },
    "nats_url": {
      "type": "string"
    },
    "manifest_version": {
      "default": 1,
      "type": "integer"
    },
    "subject_root": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "agent_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "app": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "roster": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "episode_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "resolved_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "role",
    "class",
    "nats_url"
  ],
  "type": "object",
  "title": "Manifest"
}
