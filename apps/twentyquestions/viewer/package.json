{
  "name": "twentyquestions-viewer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Twenty Questions viewer: a Svelte web app that talks ONLY to the episode service (ADR-0003) — never NATS — rendering an episode's normalized feed as a chat-room transcript, the same for live and replay. Resource and feed-event types are generated from the FreeAgent JSON Schema contract; see ./README.md.",
  "scripts": {
    "predev": "pnpm install",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "generate": "json2ts -i '../../../packages/freeagent/schemas/*.schema.json' -o src/generated && json2ts -i '../schemas/*.schema.json' -o src/generated",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^29.1.1",
    "json-schema-to-typescript": "^15.0.4",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.9"
  }
}
